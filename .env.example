# Copy to .env and fill in. .env is git-ignored.

# NVR LAN address — used as the RTSP host for cameras that route through the NVR's bridge.
WATCHTOWER_NVR_HOST=192.168.1.50
WATCHTOWER_NVR_RTSP_PORT=554
WATCHTOWER_NVR_USER=admin
WATCHTOWER_NVR_PASSWORD=change-me

# Default stream quality: "high" (=video1, archival) or "low" (=video2, mobile/CV)
WATCHTOWER_DEFAULT_STREAM=low

# Per-camera mapping: comma-separated `name:channel` pairs.
# Channel is the integer used in the RTSP path (e.g. 1, 2, 3...).
# AvertX/OpenEye native cams typically use the URI form /media/video<channel>.
# Adjust to match what your NVR exposes (check the AvertX UI or run `watchtower probe`).
WATCHTOWER_CAMERAS=front-door:1,office:2,driveway:3
